# ── StarX environment ────────────────────────────────────────────────────────
# The MVP runs with NO env vars at all (in-memory store, password "admin").
# Everything below is OPTIONAL — only set what you need when connecting real data.
# Copy to .env for local dev, or set these in Railway. Nothing secret is committed.

# Web server port (Railway sets this automatically).
PORT=3000

# Datasource: "memory" (default, no config) or "sheets" (needs the Google vars below).
DATASOURCE=memory

# Platform login password for the default tenant (the manager's web login).
# Defaults to "admin" if unset — CHANGE THIS in any real deployment.
PLATFORM_PASSWORD=admin

# Set to "true" when serving over HTTPS (e.g. Railway) so session cookies are secure.
COOKIE_SECURE=false

# Cookie-signing key. If unset, a random key is generated each boot → every session
# resets on restart. SET THIS in Railway to keep logins across deploys.
SESSION_SECRET=

# Telegram bot token (from @BotFather). The worker check-in bot.
TELEGRAM_TOKEN=

# Google service-account JSON (the whole file, one line). The same account must be
# SHARED on the spreadsheet below as an Editor.
GOOGLE_CREDENTIALS=

# The default tenant's Google Sheet id (the spreadsheet holding workers/points/visits).
SHEET_ID=

# Public URL of this deployment (used in links). e.g. https://starx-production.up.railway.app
PLATFORM_URL=
