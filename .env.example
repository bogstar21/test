# ── StarX environment ────────────────────────────────────────────────────────
# The MVP runs with NO env vars at all (in-memory store, password "admin").
# Everything below is OPTIONAL — only set what you need when connecting real data.
# Copy to .env for local dev, or set these in Railway. Nothing secret is committed.

# Web server port (Railway sets this automatically).
PORT=3000

# Datasource: "memory" (default, no config), "supabase" (persistent + API, set the
# Supabase vars below) or "sheets" (needs the Google vars further down).
DATASOURCE=memory

# ── Supabase (only when DATASOURCE=supabase) ─────────────────────────────────
# Persistent storage backed by Supabase (Postgres + REST API). Create the tables
# first by running supabase/schema.sql in the Supabase SQL editor.
#   SUPABASE_URL         → Project Settings → API → Project URL
#   SUPABASE_SERVICE_KEY → Project Settings → API → service_role secret (NOT anon)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Platform login password for the default tenant (the manager's web login).
# Defaults to "admin" if unset — CHANGE THIS in any real deployment.
PLATFORM_PASSWORD=admin

# Set to "true" when serving over HTTPS (e.g. Railway) so session cookies are secure.
COOKIE_SECURE=false

# Cookie-signing key. If unset, a random key is generated each boot → every session
# resets on restart. SET THIS in Railway to keep logins across deploys.
SESSION_SECRET=

# Telegram bot token (from @BotFather). The ONE shared worker check-in bot. It lives
# only here — never in the UI. The web app just turns it on/off (Bot tab).
TELEGRAM_TOKEN=

# ── Client connector API (only if you expose /api/v1) ────────────────────────
# The client-facing connector (push workers/points, pull visits) is OFF until this
# is set — every /api/v1 call returns 503 while it's empty. Clients authenticate
# with the "X-API-Key" header. Use a long random string.
INTEGRATION_API_KEY=

# NOTE: the worker web app (PWA) has no env var — the manager turns it on/off from
# the platform (Importar y configurar → App de check-in). Workers log in by phone.

# Google service-account JSON (the whole file, one line). The same account must be
# SHARED on the spreadsheet below as an Editor.
GOOGLE_CREDENTIALS=

# The default tenant's Google Sheet id (the spreadsheet holding workers/points/visits).
SHEET_ID=

# Public URL of this deployment (used in links). e.g. https://starx-production.up.railway.app
PLATFORM_URL=
